{
  "name": "collab-whiteboard-mvp",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "clean": "rm -rf .next",
    "predev": "npm run clean",
    "prebuild": "npm run clean",
    "dev": "NODE_ENV=development node server/app.js",
    "build": "npm run lint && tsc --noEmit && next build",
    "start": "NODE_ENV=production node server/app.js",
    "lint": "eslint . --max-warnings=0",
    "format": "prettier --write .",
    "check-format": "prettier --check ."
  },
  "dependencies": {
    "jspdf": "^2.5.2",
    "next": "^14.2.30",
    "react": "18.2.0",
    "react-dom": "18.2.0",
    "ws": "^8.18.2",
    "y-websocket": "^1.5.4",
    "yjs": "^13.6.27"
  },
  "devDependencies": {
    "@types/node": "^22.15.2",
    "@types/react": "^18.3.22",
    "@types/react-dom": "^18.3.7",
    "@types/ws": "^8.5.15",
    "autoprefixer": "^10.4.21",
    "eslint": "^8.57.1",
    "eslint-config-next": "^14.2.30",
    "eslint-config-prettier": "^9.1.0",
    "postcss": "^8.5.3",
    "prettier": "^3.5.3",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.8.3"
  }
}
